# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:15432/ainative
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ainative

# === Redis ===
REDIS_URL=redis://localhost:16379/0

# === MinIO ===
MINIO_ENDPOINT=localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ainative-files

# === App ===
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production

# === Frontend ===
# Development mode default:
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# === Local Config Root ===
# Leave empty to use ~/.ai-native-os in local development.
AI_NATIVE_OS_HOME=

# === Deployment Notes ===
# Compose deployment usually uses:
# NEXT_PUBLIC_API_BASE=http://localhost:18000/api/v1
# AI_NATIVE_OS_HOME=/root/.ai-native-os
