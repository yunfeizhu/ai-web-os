# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:15432/ainative
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ainative

# === Redis ===
REDIS_URL=redis://localhost:16379/0

# === MinIO ===
MINIO_ENDPOINT=localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ainative-files

# === App ===
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production
TENCENT_MAP_KEY=your-tencent-map-key
BROWSER_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:13000,http://127.0.0.1:13000,http://localhost:16080,http://127.0.0.1:16080
BROWSER_GLOBAL_STORAGE_ENABLED=false
BROWSER_VNC_PASSWORD=

# === Frontend ===
# Development mode default:
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# === Local Config Root ===
# Leave empty to use ~/.ai-web-os in local development.
AI_NATIVE_OS_HOME=

# === Deployment Notes ===
# Compose deployment usually uses:
# NEXT_PUBLIC_API_BASE=http://localhost:18000/api/v1
# AI_NATIVE_OS_HOME=/root/.ai-web-os
