# Copy this file to docker/.env.prod and change every secret before production use.
#
# Start with:
# docker compose --env-file docker/.env.prod -f docker/docker-compose.prod.yml up -d --build

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-postgres-password
POSTGRES_DB=ainative

MINIO_ROOT_USER=ainative-minio
MINIO_ROOT_PASSWORD=replace-with-a-long-minio-password
MINIO_BUCKET=ainative-files

SECRET_KEY=replace-with-a-random-64-character-secret
APP_TIMEZONE=Asia/Shanghai
